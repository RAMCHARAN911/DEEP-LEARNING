import numpy as np
heights = np.array([160, 162, 165, 170, 168,
                    172, 169, 171, 167, 166])
mean_mle = np.mean(heights)
variance_mle = np.mean((heights - mean_mle) ** 2)
print("MLE Mean =", mean_mle)
print("MLE Variance =", variance_mle)
heads = 7
tosses = 10
p_mle = heads / tosses
print("MLE Probability =", p_mle)
